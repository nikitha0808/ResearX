# === Backend: Bedrock (auto-selected if any AWS_* is set) ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# === Fallback: direct Anthropic API (used only if AWS_* above is empty) ===
ANTHROPIC_API_KEY=

# === Trello ===
TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_NAME=Papers Arena

# === Miro ===
MIRO_TOKEN=

# === Reviewer config ===
# On Bedrock: paste the exact model ID from your Bedrock "Model catalog" page.
# Typical format: us.anthropic.claude-opus-4-7-<date>-v1:0
# (the `us.` prefix is the cross-region inference profile — required for Opus 4)
CLAUDE_MODEL=claude-sonnet-4-6
PREFILTER_MODEL=claude-haiku-4-5-20251001
REVIEWER_MODE=computer_use
SEARCH_MAX=6
KEEP_TOP=3
MIN_RATING=5
MIN_SOUNDNESS=3
MIN_CONTRIBUTION=3

# === Per-callsite model overrides ===
# Each stage of the pipeline uses its own Claude model so you can mix-and-
# match (e.g. cheap Sonnet for review, Opus only for the visually-hardest
# Miro CU task). When unset, REVIEWER_MODEL and SYNTHESIZE_MODEL fall back
# to CLAUDE_MODEL above. MIRO_CU_MODEL has its own default of opus because
# Miro's web app is the most demanding visual UI in the pipeline.
# REVIEWER_MODEL=
# SYNTHESIZE_MODEL=
MIRO_CU_MODEL=claude-opus-4-7
